{
    "hosting": {
	"public": ".",
	"rewrites": [
	    {
		"source": "/",
		"destination": "/project.html"
	    }
	],
	"ignore": [
	    "firebase.json",
	    "**/.*",
	    "**/node_modules/**"
	],
	"headers": [
	    {
		"source": "**",
		"headers": [
		    {
			"key": "Cross-Origin-Opener-Policy",
			"value": "same-origin"
		    },
		    {
			"key": "Cross-Origin-Embedder-Policy",
			"value": "require-corp"
		    }
		]
	    }
	]
    }
}
